
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Usuario es dueño del recurso
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Reglas para la colección de usuarios y su perfil
    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      allow list: if false;

      // Favoritos como subcolección
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Los pedidos son de solo lectura para el usuario (se crean vía Server Action/ERP)
    match /orders/{orderId} {
      allow read: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow write: if false; // Solo el sistema ERP escribe aquí
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
