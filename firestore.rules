rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la colección de usuarios
    match /users/{userId} {
      // Un usuario solo puede leer su propio perfil
      allow get: if request.auth != null && request.auth.uid == userId;
      
      // Un usuario puede crear su perfil si está autenticado y el ID coincide
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Un usuario puede actualizar su perfil si está autenticado y es el dueño
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Por seguridad, no permitimos listar (list) toda la colección de usuarios
      allow list: if false;
    }
    
    // Regla por defecto: denegar todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}