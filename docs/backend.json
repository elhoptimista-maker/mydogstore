
{
  "entities": {
    "User": {
      "title": "Usuario",
      "description": "Perfil de usuario registrado en el e-commerce.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "WishlistItem": {
      "title": "Favorito",
      "description": "Producto guardado en la lista de deseos del usuario.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Pedido",
      "description": "Registro de una compra realizada por el usuario.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Colección de perfiles de usuario."
    },
    "/users/{userId}/wishlist/{productId}": {
      "schema": "WishlistItem",
      "description": "Subcolección de productos favoritos por usuario."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Colección global de pedidos (Gestionada por ERP)."
    }
  }
}
